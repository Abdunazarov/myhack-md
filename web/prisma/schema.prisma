generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum ProjectState {
  Lead
  In_Program
  Graduated
  Dead
}

enum ApplicationStatus {
  Submitted
  Auditing
  Audited
  Eligible
  Rejected
  Routed
  Needs_Review
}

enum ProgrammeType {
  Grant
  Pre_Accelerator
  Mentorship
  VC_Readiness
  Sandbox
}

enum RuleType {
  Hard
  Soft
}

enum RoutingDecisionType {
  Grant_Eligible
  Auto_Routed
  Needs_Review
  Rejected
}

enum UserRole {
  Admin
  Founder
  Mentor
  Investor
}

enum LinkageStatus {
  Active
  Completed
  Requires_Intervention
  Cancelled
}

enum LinkageOutcome {
  Success
  Fail
  Pivot
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         UserRole
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  mentorNode MentorNode?
}

model EcosystemProject {
  id               String       @id @default(cuid())
  name             String
  state            ProjectState @default(Lead)
  sector           String
  stage            String
  country          String
  founderName      String
  founderEmail     String
  metricsHistory   String       @default("{}")
  passportSnapshot String       @default("{}")
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  applications      Application[]
  linkages          LinkageEntity[]
  roadblockRequests RoadblockRequest[]
}

model Programme {
  id          String        @id @default(cuid())
  slug        String        @unique
  name        String
  type        ProgrammeType
  description String
  priority    Int           @default(0)
  active      Boolean       @default(true)

  rules        ProgrammeRule[]
  applications Application[] @relation("TargetProgramme")
  routingFrom  RoutingDecision[] @relation("FromProgramme")
  routingTo    RoutingDecision[] @relation("RecommendedProgramme")
}

model ProgrammeRule {
  id            String   @id @default(cuid())
  programmeId   String
  ruleKey       String
  ruleType      RuleType
  operator      String
  expectedValue String
  failureReason String
  weight        Float    @default(1)

  programme Programme @relation(fields: [programmeId], references: [id], onDelete: Cascade)

  @@index([programmeId])
}

model BenchmarkProfile {
  id                    String @id @default(cuid())
  sector                String
  stage                 String
  metricName            String
  p25                   Float
  median                Float
  p75                   Float
  successfulCohortCount Int    @default(0)
  sourceCohortYear      Int

  @@index([sector, stage, metricName])
}

model Application {
  id                    String            @id @default(cuid())
  ecosystemProjectId    String
  targetProgrammeId     String
  status                ApplicationStatus @default(Submitted)
  rawApplication        String            @default("{}")
  normalizedApplication String            @default("{}")
  pitchText             String?
  pitchDeckFileName     String?
  pitchDeckMimeType     String?
  pitchDeckText         String?
  financialMetrics      String            @default("{}")
  financialModelSummary String?
  submittedAt           DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  ecosystemProject EcosystemProject @relation(fields: [ecosystemProjectId], references: [id], onDelete: Cascade)
  targetProgramme  Programme          @relation("TargetProgramme", fields: [targetProgrammeId], references: [id])
  intakeAudits     IntakeAudit[]
  routingDecisions RoutingDecision[]
}

model IntakeAudit {
  id                 String   @id @default(cuid())
  applicationId      String
  readinessScore     Float
  aiSummary          String?
  founderReport      String?
  strengths          String   @default("[]")
  riskFlags          String   @default("[]")
  missingInformation String   @default("[]")
  benchmarkDeltas    String   @default("[]")
  eligibilityResult  String   @default("{}")
  scoreBreakdown     String   @default("{}")
  modelUsed          String?
  aiFallback         Boolean  @default(false)
  createdAt          DateTime @default(now())

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
}

model RoutingDecision {
  id                     String              @id @default(cuid())
  applicationId          String
  fromProgrammeId        String?
  recommendedProgrammeId String
  decisionType           RoutingDecisionType
  reasonCodes            String              @default("[]")
  explanation            String
  adminConfirmed         Boolean             @default(false)
  adminNote              String?
  createdAt              DateTime            @default(now())

  application          Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  fromProgramme        Programme?  @relation("FromProgramme", fields: [fromProgrammeId], references: [id])
  recommendedProgramme Programme   @relation("RecommendedProgramme", fields: [recommendedProgrammeId], references: [id])

  @@index([applicationId])
}

model AuditEvent {
  id         String   @id @default(cuid())
  entityType String
  entityId   String
  eventType  String
  actorType  String
  metadata   String   @default("{}")
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
}

// --- Module 2: Dynamic Cohort Orchestration ---

model MentorNode {
  id                   String   @id @default(cuid())
  userId               String?  @unique
  name                 String
  email                String   @unique
  title                String
  availabilityCapacity Int      @default(5)
  dynamicSkillMatrix   String   @default("{}")
  outcomeSummary       String   @default("{}")
  active               Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user                User?               @relation(fields: [userId], references: [id])
  historicalOutcomes  HistoricalOutcome[]
  linkages            LinkageEntity[]
}

model HistoricalOutcome {
  id           String         @id @default(cuid())
  mentorNodeId String
  startupName  String
  sector       String
  stage        String
  problemTags  String         @default("[]")
  outcome      LinkageOutcome
  feedbackLog  String
  cohortYear   Int            @default(2024)
  createdAt    DateTime       @default(now())

  mentor MentorNode @relation(fields: [mentorNodeId], references: [id], onDelete: Cascade)

  @@index([mentorNodeId])
}

model LinkageEntity {
  id                 String          @id @default(cuid())
  ecosystemProjectId String
  mentorNodeId       String
  goal               String
  problemTags        String          @default("[]")
  status             LinkageStatus   @default(Active)
  healthScore        Float           @default(100)
  finalOutcome       LinkageOutcome?
  matchScore         Float?
  matchExplanation   String?
  feedbackLogs       String          @default("[]")
  lastActivityAt     DateTime        @default(now())
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  ecosystemProject EcosystemProject @relation(fields: [ecosystemProjectId], references: [id], onDelete: Cascade)
  mentor           MentorNode       @relation(fields: [mentorNodeId], references: [id])

  @@index([ecosystemProjectId])
  @@index([mentorNodeId])
  @@index([status])
}

model RoadblockRequest {
  id                 String   @id @default(cuid())
  ecosystemProjectId String
  roadblock          String
  problemCategory    String?
  stage              String
  sector             String
  status             String   @default("matched")
  matchedLinkageId   String?
  matchExplanation   String?
  createdAt          DateTime @default(now())

  ecosystemProject EcosystemProject @relation(fields: [ecosystemProjectId], references: [id], onDelete: Cascade)

  @@index([ecosystemProjectId])
}
